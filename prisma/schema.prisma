// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles for core users of your app.
enum UserRole {
  ADMIN
  USER
}

/// High-level activity types for the audit trail.
enum ActivityType {
  WALLET_CONNECTED
  WALLET_DISCONNECTED
  LOGIN
  LOGOUT
  NONCE_ISSUED
  NONCE_USED
  CONTEST_VIEW
  CONTEST_JOINED
  FEE_PAID
  FEE_REFUNDED
  PARTICIPATION_STATUS_CHANGED
  CUSTOM
}

/// Participation status for a contest.
enum ParticipationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}

/// Core user of your app (admin or player).
model User {
  id        String   @id @default(cuid())
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  wallets        Wallet[]
  sessions       Session[]
  activities     Activity[]
  participations Participation[]

  @@map("users")
}

/// A blockchain wallet that can sign in (SIWS / Phantom).
model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  provider  String?
  createdAt DateTime @default(now())

  // Optional owner
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Back-relations
  nonces         Nonce[]
  sessions       Session[]
  activities     Activity[]
  participations Participation[]

  @@index([userId])
  @@map("wallets")
}

/// Server-issued short-lived nonce used for SIWS.
model Nonce {
  id        String   @id @default(cuid())
  value     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("nonces")
}

/// Session (JWT jti or server-managed session).
model Session {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  validUntil DateTime?
  ip         String?
  userAgent  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  activities Activity[]

  @@index([userId])
  @@index([walletId])
  @@map("sessions")
}

/// Contest catalog.
model Contest {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  /// Optional entry fee in your base unit (e.g., lamports/wei/cents)
  entryFee  Int?
  metadata  Json?
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  participations Participation[]
  activities     Activity[]

  @@map("contests")
}

/// Participation of a user in a contest, with fee and tx info.
model Participation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status  ParticipationStatus @default(PENDING)
  /// Paid fee in base unit (e.g., lamports/wei/cents)
  paidFee Int?
  txHash  String?

  // Relations
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  activities Activity[]

  @@index([contestId])
  @@index([userId])
  @@index([walletId])
  @@map("participations")
}

/// Audit trail of important events.
model Activity {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  type        ActivityType
  description String?
  /// Optional numeric amount (fees, rewards) in base unit
  amount      Int?
  txHash      String?
  metadata    Json?

  // Foreign keys (all optional to let you log broadly)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  contestId String?
  contest   Contest? @relation(fields: [contestId], references: [id])

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])

  participationId String?
  participation   Participation? @relation(fields: [participationId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@index([contestId])
  @@index([sessionId])
  @@index([participationId])
  @@map("activities")
}
